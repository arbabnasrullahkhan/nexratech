                    </ul>
                </div>
                <div id="dash-settings" class="hidden">
                    <h2>Recording Preferences</h2>
                    <div class="form-group" style="margin-top: 20px;">
                        <label>Video Quality</label>
                        <select id="set-quality" class="form-control">
                            <option value="1080">1080p Full HD</option>
                            <option value="2160">4K Ultra HD</option>
                            <option value="720">720p Standard</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Frame Rate (FPS)</label>
                        <select id="set-fps" class="form-control">
                            <option value="60">60 FPS (Gaming/Smooth)</option>
                            <option value="30">30 FPS (Standard)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Countdown Timer</label>
                        <select id="set-countdown" class="form-control">
                            <option value="7">7 Seconds (Nexra Default)</option>
                            <option value="3">3 Seconds</option>
                            <option value="0">None</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- STUDIO PAGE (OBS STYLE) -->
    <main id="studio-page" class="view-section">
        <div class="studio-container">
            <div class="preview-wrapper frosted-panel">
                <!-- Main Screen Video -->
                <video id="screen-preview" autoplay muted playsinline></video>
                <!-- Annotation Layer -->
                <canvas id="annotation-canvas"></canvas>
                
                <!-- PiP Webcam -->
                <div id="pip-cam-container" class="pip-container shape-circle hidden">
                    <video id="webcam-preview" autoplay muted playsinline></video>
                </div>
                
                <!-- Center Watermark Overlay (Visible only for preview aesthetic, hidden on actual record stream) -->
                <img id="overlay-watermark" src="https://uploads.onecompiler.io/42yatf6fu/1781259030437/12945C3A-733B-45AB-9722-044C592AC5C7-removebg-preview.png" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); opacity: 0.05; pointer-events: none; width: 300px; display: none;">
            </div>

            <div class="controls-bar frosted-panel">
                <div class="flex gap-4 align-center">
                    <button class="btn btn-primary" id="btn-start-record">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg> Start Recording
                    </button>
                    <button class="btn btn-glass hidden" id="btn-stop-record" style="color: #ff3333; border-color: #ff3333;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg> Stop Recording
                    </button>
                    <span id="record-timer" style="font-family: monospace; font-size: 18px; display: none;">00:00</span>
                </div>
                
                <div class="flex gap-2">
                    <!-- Source Toggles -->
                    <button class="icon-btn" id="btn-toggle-screen" title="Screen Source" onclick="recorder.toggleScreen()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    </button>
                    <button class="icon-btn" id="btn-toggle-cam" title="Toggle Webcam PiP" onclick="recorder.toggleCamera()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                    </button>
                    <button class="icon-btn" id="btn-toggle-mic" title="Toggle Microphone" onclick="recorder.toggleMic()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8"/></svg>
                    </button>
                    <!-- Audio Meter -->
                    <div class="audio-meter" id="mic-meter">
                        <div class="meter-bar"></div><div class="meter-bar"></div><div class="meter-bar"></div><div class="meter-bar"></div><div class="meter-bar"></div>
                    </div>
                </div>

                <div class="flex gap-2">
                    <!-- Annotation Tools -->
                    <button class="icon-btn" id="btn-tool-pen" title="Draw" onclick="tools.setTool('pen')">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
                    </button>
                    <button class="icon-btn" id="btn-tool-clear" title="Clear Annotations" onclick="tools.clearCanvas()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    </button>
                    <!-- PiP Controls -->
                    <button class="icon-btn" title="Change PiP Shape" onclick="recorder.cyclePiPShape()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- PREVIEW & EXPORT STUDIO -->
    <main id="preview-page" class="view-section">
        <div style="max-width: 900px; margin: 0 auto; text-align: center;">
            <h2>Review & Export</h2>
            <p style="color: var(--text-muted); margin-bottom: 20px;">The watermark will be securely burned into your final file during export.</p>
            
            <div class="frosted-panel" style="padding: 10px; margin-bottom: 20px;">
                <video id="final-preview-video" controls style="width: 100%; border-radius: 8px; background: #000;"></video>
            </div>

            <!-- Export Section -->
            <div class="frosted-panel" style="padding: 24px; text-align: left;" id="export-box">
                <div class="flex" style="justify-content: space-between; align-items: center;">
                    <div>
                        <h3 class="text-orange">Ready for Export</h3>
                        <p style="font-size: 14px; color: var(--text-muted);">High-Quality MP4 • Hardware Accelerated</p>
                    </div>
                    <button class="btn btn-primary" id="btn-export-download" onclick="engine.initiateExport()">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                        Burn & Download
                    </button>
                </div>
                <div id="export-progress-container" class="hidden" style="margin-top: 20px;">
                    <div class="flex" style="justify-content: space-between; font-size: 13px;">
                        <span>Rendering Engine Active...</span>
                        <span id="export-percent">0%</span>
                    </div>
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" id="export-progress-bar"></div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- COUNTDOWN OVERLAY -->
    <div id="countdown-overlay">
        <div id="countdown-number">7</div>
    </div>

    <!-- MODALS -->
    <!-- Auth Modal -->
    <div class="modal-overlay" id="auth-modal">
        <div class="modal-content frosted-panel">
            <button class="icon-btn" style="position: absolute; top: 16px; right: 16px;" onclick="ui.hideModal('auth-modal')">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
            <h2 style="margin-bottom: 8px;">Sign In to Export</h2>
            <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 24px;">Authentication is required to trigger the Nexra Canvas Engine and download your file.</p>
            
            <div id="auth-error" style="color: #ff3333; font-size: 13px; margin-bottom: 10px; display: none;"></div>

            <div class="form-group">
                <input type="email" id="auth-email" class="form-control" placeholder="Email Address">
            </div>
            <div class="form-group">
                <input type="password" id="auth-pass" class="form-control" placeholder="Password">
            </div>
            
            <button class="btn btn-primary" style="width: 100%; margin-bottom: 16px;" onclick="authManager.signInEmail()">Continue with Email</button>
            
            <div style="text-align: center; margin: 16px 0; font-size: 12px; color: var(--text-muted);">OR</div>
            
            <button class="btn btn-glass" style="width: 100%;" onclick="authManager.signInGoogle()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M21.35 11.1h-9.17v2.73h6.51c-.33 3.81-3.5 5.44-6.5 5.44C8.36 19.27 5 16.25 5 12c0-4.1 3.2-7.27 7.2-7.27 3.09 0 4.9 1.97 4.9 1.97L19 4.72S16.56 2 12.1 2C6.42 2 2.03 6.8 2.03 12c0 5.05 4.13 10 10.22 10 5.35 0 9.25-3.67 9.25-9.09 0-1.15-.15-1.81-.15-1.81z"/></svg>
                Sign in with Google
            </button>
            
            <div style="margin-top: 20px; font-size: 12px; text-align: center; color: var(--text-muted); cursor: pointer;" onclick="authManager.toggleMode()">
                <span id="auth-toggle-text">Need an account? Register</span>
            </div>
        </div>
    </div>

    <!-- TOAST CONTAINER -->
    <div id="toast-container"></div>

    <!-- HIDDEN ELEMENTS FOR WATERMARK BURN ENGINE -->
    <div style="display:none;">
        <video id="burn-video" playsinline muted></video>
        <canvas id="burn-canvas"></canvas>
        <img id="asset-logo" src="https://uploads.onecompiler.io/42yatf6fu/1781258941988/25088C4A-230C-4E61-8E84-C40FD3A6033C-removebg-preview.png" crossorigin="anonymous">
        <img id="asset-watermark" src="https://uploads.onecompiler.io/42yatf6fu/1781259030437/12945C3A-733B-45AB-9722-044C592AC5C7-removebg-preview.png" crossorigin="anonymous">
    </div>

    <!-- ========================================== -->
    <!-- APPLICATION LOGIC (Vanilla JS + Firebase) -->
    <!-- ========================================== -->
    <script type="module">
        // ---------------------------------------------------------
        // 1. FIREBASE INTEGRATION & ARCHITECTURE
        // Standard ES Module dynamic import to prevent file-not-found crash.
        // Falls back to "Local Guest Mode" if config is missing.
        // ---------------------------------------------------------
        let fbApp, fbAuth, fbDb;
        let authModule, firestoreModule;
        
        const initFirebase = async () => {
            try {
                // Assuming firebase-config.js exports standard init modules.
                // For a single file robustness, we'll import SDKs from CDN, and config locally.
                const { initializeApp } = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js');
                authModule = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js');
                firestoreModule = await import('https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js');
                
                try {
                    const configModule = await import('./firebase-config.js');
                    fbApp = configModule.app || initializeApp(configModule.default || configModule.firebaseConfig);
                } catch(e) {
                    console.warn("firebaseconfig.js not found. Running in Offline/Local Mode.");
                    // Dummy mock to allow UI to function normally without crashing
                    window.isLocalMode = true;
                    return;
                }

                fbAuth = authModule.getAuth(fbApp);
                fbDb = firestoreModule.getFirestore(fbApp);
                
                authModule.onAuthStateChanged(fbAuth, (user) => {
                    appState.user = user;
                    if(user) {
                        ui.toast(`Welcome back, ${user.email.split('@')[0]}`);
                        document.getElementById('btn-header-auth').innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg> Sign Out';
                        document.getElementById('btn-header-auth').onclick = () => authModule.signOut(fbAuth);
                        ui.hideModal('auth-modal');
                        // Auto-resume download if pending
                        if(appState.pendingExport) {
                            engine.initiateExport();
                        }
                    } else {
                        document.getElementById('btn-header-auth').innerHTML = 'Sign In';
                        document.getElementById('btn-header-auth').onclick = () => ui.showModal('auth-modal');
                    }
                });
            } catch (err) {
                console.error("Firebase Init Error:", err);
                window.isLocalMode = true;
            }
        };

        // ---------------------------------------------------------
        // 2. STATE MANAGEMENT
        // ---------------------------------------------------------
        window.appState = {
            user: null,
            isRecording: false,
            recordingBlob: null,
            pendingExport: false,
            settings: { fps: 60, quality: 1080, countdown: 7 },
            pipShape: 'circle' // circle, square, rect
        };

        // ---------------------------------------------------------
        // 3. UI & ROUTING UTILITIES
        // ---------------------------------------------------------
        window.ui = {
            toast: (msg) => {
                const container = document.getElementById('toast-container');
                const t = document.createElement('div');
                t.className = 'toast';
                t.innerText = msg;
                container.appendChild(t);
                setTimeout(() => { t.style.opacity = '0'; setTimeout(()=>t.remove(), 300); }, 3000);
            },
            showModal: (id) => document.getElementById(id).classList.add('active'),
            hideModal: (id) => document.getElementById(id).classList.remove('active'),
            switchDashTab: (tab) => {
                ['home', 'history', 'settings'].forEach(t => {
                    document.getElementById(`dash-${t}`).classList.add('hidden');
                    document.querySelectorAll('.sidebar .menu-item').forEach(el => el.classList.remove('active'));
                });
                document.getElementById(`dash-${tab}`).classList.remove('hidden');
                event.currentTarget.classList.add('active');
            }
        };

        window.app = {
            navigate: (page) => {
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                document.getElementById(`${page}-page`).classList.add('active');
                if(page === 'studio') {
                    if(!recorder.screenStream) ui.toast("Select a source to begin.");
                }
            }
        };

        // ---------------------------------------------------------
        // 4. MEDIA & RECORDING ENGINE (OBS STYLE)
        // ---------------------------------------------------------
        let mediaRecorder;
        let recordedChunks = [];
        let recordStartTime;
        let timerInterval;

        window.recorder = {
            screenStream: null,
            camStream: null,
            micStream: null,
            audioCtx: null,
            dest: null,
            mixedStream: new MediaStream(),

            toggleScreen: async () => {
                try {
                    if(recorder.screenStream) {
                        recorder.screenStream.getTracks().forEach(t => t.stop());
                        recorder.screenStream = null;
                        document.getElementById('screen-preview').srcObject = null;
                        document.getElementById('btn-toggle-screen').classList.remove('active');
                        return;
                    }
                    const fps = parseInt(document.getElementById('set-fps').value) || 60;
                    recorder.screenStream = await navigator.mediaDevices.getDisplayMedia({
                        video: { frameRate: { ideal: fps } },
                        audio: { echoCancellation: true, noiseSuppression: true }
                    });
                    document.getElementById('screen-preview').srcObject = recorder.screenStream;
                    document.getElementById('btn-toggle-screen').classList.add('active');
                    
                    // Re-mix audio if screen has audio
                    recorder.setupAudioMixing();
                } catch(e) { console.error(e); ui.toast("Screen capture cancelled."); }
            },

            toggleCamera: async () => {
                const pip = document.getElementById('pip-cam-container');
                if(recorder.camStream) {
                    recorder.camStream.getTracks().forEach(t => t.stop());
                    recorder.camStream = null;
                    pip.classList.add('hidden');
                    document.getElementById('btn-toggle-cam').classList.remove('active');
                    return;
                }
                try {
                    recorder.camStream = await navigator.mediaDevices.getUserMedia({ video: true });
                    document.getElementById('webcam-preview').srcObject = recorder.camStream;
                    pip.classList.remove('hidden');
                    document.getElementById('btn-toggle-cam').classList.add('active');
                } catch(e) { ui.toast("Camera access denied."); }
            },

            toggleMic: async () => {
                if(recorder.micStream) {
                    recorder.micStream.getTracks().forEach(t => t.stop());
                    recorder.micStream = null;
                    document.getElementById('btn-toggle-mic').classList.remove('active');
                    return;
                }
                try {
                    recorder.micStream = await navigator.mediaDevices.getUserMedia({ 
                        audio: { echoCancellation: true, noiseSuppression: true } 
                    });
                    document.getElementById('btn-toggle-mic').classList.add('active');
                    recorder.setupAudioMixing();
                    recorder.setupAudioMeter();
                } catch(e) { ui.toast("Mic access denied."); }
            },

            cyclePiPShape: () => {
                const pip = document.getElementById('pip-cam-container');
                pip.classList.remove(`shape-${appState.pipShape}`);
                const shapes = ['circle', 'square', 'rect'];
                let idx = shapes.indexOf(appState.pipShape);
                appState.pipShape = shapes[(idx + 1) % shapes.length];
                pip.classList.add(`shape-${appState.pipShape}`);
            },

            setupAudioMixing: () => {
                if(!recorder.audioCtx) recorder.audioCtx = new AudioContext();
                if(recorder.dest) recorder.dest.disconnect();
                recorder.dest = recorder.audioCtx.createMediaStreamDestination();
                
                if(recorder.screenStream && recorder.screenStream.getAudioTracks().length > 0) {
                    const screenSource = recorder.audioCtx.createMediaStreamSource(new MediaStream([recorder.screenStream.getAudioTracks()[0]]));
                    screenSource.connect(recorder.dest);
                }
                if(recorder.micStream && recorder.micStream.getAudioTracks().length > 0) {
                    const micSource = recorder.audioCtx.createMediaStreamSource(recorder.micStream);
                    micSource.connect(recorder.dest);
                }
                
                recorder.mixedStream = new MediaStream();
                if(recorder.screenStream) recorder.screenStream.getVideoTracks().forEach(t => recorder.mixedStream.addTrack(t));
                recorder.dest.stream.getAudioTracks().forEach(t => recorder.mixedStream.addTrack(t));
            },

            setupAudioMeter: () => {
                const analyser = recorder.audioCtx.createAnalyser();
                const source = recorder.audioCtx.createMediaStreamSource(recorder.micStream);
                source.connect(analyser);
                analyser.fftSize = 32;
                const dataArray = new Uint8Array(analyser.frequencyBinCount);
                const bars = document.querySelectorAll('.meter-bar');
                
                const updateMeter = () => {
                    if(!recorder.micStream) return;
                    requestAnimationFrame(updateMeter);
                    analyser.getByteFrequencyData(dataArray);
                    let sum = dataArray.reduce((a,b)=>a+b, 0);
                    let avg = sum / dataArray.length;
                    let activeBars = Math.floor(avg / 25);
                    bars.forEach((bar, i) => {
                        bar.style.height = i < activeBars ? '12px' : '4px';
                        bar.style.background = i < activeBars ? 'var(--orange)' : 'var(--glass-border)';
                    });
                };
                updateMeter();
            },

            startRecordingSequence: async () => {
                if(!recorder.screenStream) { ui.toast("Please select a screen source first."); return; }
                const countdownVal = parseInt(document.getElementById('set-countdown').value);
                if(countdownVal > 0) {
                    const overlay = document.getElementById('countdown-overlay');
                    const num = document.getElementById('countdown-number');
                    overlay.style.display = 'flex';
                    let count = countdownVal;
                    num.innerText = count;
                    const cInt = setInterval(() => {
                        count--;
                        if(count === 0) {
                            clearInterval(cInt);
                            overlay.style.display = 'none';
                            recorder.startActualRecording();
                        } else { num.innerText = count; }
                    }, 1000);
                } else {
                    recorder.startActualRecording();
                }
            },

            startActualRecording: () => {
                recordedChunks = [];
                // We record the mixed raw stream. Watermark is added later.
                try {
                    const options = { mimeType: 'video/webm; codecs=vp9' };
                    mediaRecorder = new MediaRecorder(recorder.mixedStream, options);
                } catch(e) {
                    mediaRecorder = new MediaRecorder(recorder.mixedStream); // Fallback
                }
                
                mediaRecorder.ondataavailable = e => { if(e.data.size > 0) recordedChunks.push(e.data); };
                mediaRecorder.onstop = recorder.processRecording;
                mediaRecorder.start(1000);
                
                appState.isRecording = true;
                document.getElementById('btn-start-record').classList.add('hidden');
                document.getElementById('btn-stop-record').classList.remove('hidden');
                
                // Timer
                recordStartTime = Date.now();
                document.getElementById('record-timer').style.display = 'block';
                timerInterval = setInterval(() => {
                    let diff = Math.floor((Date.now() - recordStartTime) / 1000);
                    let m = String(Math.floor(diff / 60)).padStart(2, '0');
                    let s = String(diff % 60).padStart(2, '0');
                    document.getElementById('record-timer').innerText = `${m}:${s}`;
                }, 1000);
                ui.toast("Recording Started...");
            },

            stopRecording: () => {
                if(mediaRecorder && mediaRecorder.state !== 'inactive') {
                    mediaRecorder.stop();
                }
                appState.isRecording = false;
                clearInterval(timerInterval);
                document.getElementById('btn-start-record').classList.remove('hidden');
                document.getElementById('btn-stop-record').classList.add('hidden');
                document.getElementById('record-timer').style.display = 'none';
            },

            processRecording: () => {
                const blob = new Blob(recordedChunks, { type: 'video/webm' });
                appState.recordingBlob = blob;
                
                // Set to preview
                const url = URL.createObjectURL(blob);
                document.getElementById('final-preview-video').src = url;
                
                // Clean up streams to save memory
                if(recorder.screenStream) recorder.screenStream.getTracks().forEach(t=>t.stop());
                if(recorder.micStream) recorder.micStream.getTracks().forEach(t=>t.stop());
                recorder.screenStream = null;
                document.getElementById('btn-toggle-screen').classList.remove('active');
                
                ui.toast("Recording Captured Locally!");
                app.navigate('preview');
            }
        };

        // Event Listeners for Recording
        document.getElementById('btn-start-record').addEventListener('click', recorder.startRecordingSequence);
        document.getElementById('btn-stop-record').addEventListener('click', recorder.stopRecording);

        // PiP Dragging Logic
        const pip = document.getElementById('pip-cam-container');
        let isDragging = false, startX, startY, initialX, initialY;
        pip.addEventListener('mousedown', e => {
            isDragging = true; startX = e.clientX; startY = e.clientY;
            initialX = pip.offsetLeft; initialY = pip.offsetTop;
            pip.style.transition = 'none';
        });
        window.addEventListener('mousemove', e => {
            if(!isDragging) return;
            const dx = e.clientX - startX; const dy = e.clientY - startY;
            pip.style.left = `${initialX + dx}px`;
            pip.style.top = `${initialY + dy}px`;
            pip.style.bottom = 'auto'; pip.style.right = 'auto';
        });
        window.addEventListener('mouseup', () => { isDragging = false; pip.style.transition = 'border-radius 0.3s ease'; });


        // ---------------------------------------------------------
        // 5. ANNOTATION TOOLS (Overlay Canvas)
        // ---------------------------------------------------------
        const canvas = document.getElementById('annotation-canvas');
        const ctx = canvas.getContext('2d');
        let isDrawing = false;
        
        const resizeCanvas = () => {
            const rect = document.querySelector('.preview-wrapper').getBoundingClientRect();
            canvas.width = rect.width; canvas.height = rect.height;
        };
        window.addEventListener('resize', resizeCanvas);
        setTimeout(resizeCanvas, 1000);

        window.tools = {
            active: null,
            setTool: (t) => {
                tools.active = tools.active === t ? null : t;
                document.getElementById('btn-tool-pen').classList.toggle('active', tools.active === 'pen');
                canvas.style.pointerEvents = tools.active ? 'auto' : 'none';
            },
            clearCanvas: () => ctx.clearRect(0, 0, canvas.width, canvas.height)
        };

        canvas.addEventListener('mousedown', e => {
            if(!tools.active) return;
            isDrawing = true;
            ctx.beginPath();
            ctx.moveTo(e.offsetX, e.offsetY);
        });
        canvas.addEventListener('mousemove', e => {
            if(!isDrawing || !tools.active) return;
            ctx.lineWidth = 4;
            ctx.lineCap = 'round';
            ctx.strokeStyle = '#FF5A00';
            ctx.lineTo(e.offsetX, e.offsetY);
            ctx.stroke();
        });
        canvas.addEventListener('mouseup', () => isDrawing = false);

        // ---------------------------------------------------------
        // 6. THE BURN ENGINE (Canvas + MediaRecorder for Export)
        // ---------------------------------------------------------
        window.engine = {
            initiateExport: async () => {
                // Auth Gateway
                if(!appState.user && !window.isLocalMode) {
                    appState.pendingExport = true;
                    ui.showModal('auth-modal');
                    return;
                }
                
                if(!appState.recordingBlob) { ui.toast("No recording found."); return; }

                document.getElementById('btn-export-download').classList.add('hidden');
                document.getElementById('export-progress-container').classList.remove('hidden');
                const pBar = document.getElementById('export-progress-bar');
                const pText = document.getElementById('export-percent');

                // Setup Burn Engine
                const burnVideo = document.getElementById('burn-video');
                const burnCanvas = document.getElementById('burn-canvas');
                const bCtx = burnCanvas.getContext('2d');
                const logo = document.getElementById('asset-logo');
                const wMark = document.getElementById('asset-watermark');

                burnVideo.src = URL.createObjectURL(appState.recordingBlob);
                await new Promise(r => burnVideo.onloadedmetadata = r);
                
                burnCanvas.width = burnVideo.videoWidth;
                burnCanvas.height = burnVideo.videoHeight;

                const burnStream = burnCanvas.captureStream(60);
                
                // Extract Audio from Original Blob via dummy audio context or stream copy
                // To keep it simple in browser: we play the video unmuted, and capture stream if supported
                const originalVideoStream = burnVideo.captureStream ? burnVideo.captureStream() : burnVideo.mozCaptureStream();
                if(originalVideoStream && originalVideoStream.getAudioTracks().length > 0) {
                    burnStream.addTrack(originalVideoStream.getAudioTracks()[0]);
                }

                const burnRecorder = new MediaRecorder(burnStream, { mimeType: 'video/webm; codecs=vp9' });
                const burnChunks = [];
                burnRecorder.ondataavailable = e => burnChunks.push(e.data);
                
                burnRecorder.onstop = () => {
                    const finalBlob = new Blob(burnChunks, { type: 'video/webm' }); // WebM acts as MP4 in modern browsers via wrapper
                    const url = URL.createObjectURL(finalBlob);
                    const a = document.createElement('a');
                    a.style.display = 'none';
                    a.href = url;
                    a.download = `Nexra_Export_${Date.now()}.webm`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    
                    document.getElementById('export-progress-container').classList.add('hidden');
                    document.getElementById('btn-export-download').classList.remove('hidden');
                    ui.toast("Export Complete! File downloaded.");
                    appState.pendingExport = false;
                };

                // The Render Loop
                burnVideo.play();
                burnRecorder.start();

                const drawFrame = () => {
                    if(burnVideo.paused || burnVideo.ended) {
                        burnRecorder.stop();
                        return;
                    }
                    
                    // Draw raw video
                    bCtx.drawImage(burnVideo, 0, 0, burnCanvas.width, burnCanvas.height);
                    
                    // Burn Watermarks
                    // 1. Center Low-Opacity Mark
                    bCtx.globalAlpha = 0.15;
                    const mw = burnCanvas.width * 0.3;
                    const mh = mw * (wMark.height / wMark.width);
                    bCtx.drawImage(wMark, (burnCanvas.width - mw)/2, (burnCanvas.height - mh)/2, mw, mh);
                    
                    // 2. Corner Logo
                    bCtx.globalAlpha = 1.0;
                    bCtx.drawImage(logo, burnCanvas.width - 150, 30, 120, 120 * (logo.height/logo.width));

                    // Progress Update UI
                    let pct = Math.min(100, Math.floor((burnVideo.currentTime / burnVideo.duration) * 100));
                    pBar.style.width = `${pct}%`;
                    pText.innerText = `${pct}%`;

                    requestAnimationFrame(drawFrame);
                };
                drawFrame();
            }
        };

        // ---------------------------------------------------------
        // 7. AUTH & FIREBASE SYNC LOGIC
        // ---------------------------------------------------------
        let isRegisterMode = false;
        window.authManager = {
            toggleMode: () => {
                isRegisterMode = !isRegisterMode;
                document.getElementById('auth-toggle-text').innerText = isRegisterMode ? "Already have an account? Sign In" : "Need an account? Register";
            },
            signInEmail: async () => {
                if(window.isLocalMode) { ui.toast("Local Mode Active. Export Unlocked."); ui.hideModal('auth-modal'); engine.initiateExport(); return; }
                const e = document.getElementById('auth-email').value;
                const p = document.getElementById('auth-pass').value;
                try {
                    if(isRegisterMode) {
                        await authModule.createUserWithEmailAndPassword(fbAuth, e, p);
                    } else {
                        await authModule.signInWithEmailAndPassword(fbAuth, e, p);
                    }
                } catch(err) {
                    document.getElementById('auth-error').innerText = err.message;
                    document.getElementById('auth-error').style.display = 'block';
                }
            },
            signInGoogle: async () => {
                if(window.isLocalMode) { ui.toast("Local Mode Active. Export Unlocked."); ui.hideModal('auth-modal'); engine.initiateExport(); return; }
                try {
                    const provider = new authModule.GoogleAuthProvider();
                    await authModule.signInWithPopup(fbAuth, provider);
                } catch(err) {
                    document.getElementById('auth-error').innerText = err.message;
                    document.getElementById('auth-error').style.display = 'block';
                }
            }
        };

        // Initialize Everything
        window.onload = async () => {
            await initFirebase();
            
            // Register Inline Service Worker for PWA Offline Mode
            const swCode = `
                const CACHE_NAME = 'nexra-v1';
                self.addEventListener('install', e => {
                    e.waitUntil(caches.open(CACHE_NAME).then(c => c.addAll(['/'])));
                });
                self.addEventListener('fetch', e => {
                    e.respondWith(caches.match(e.request).then(res => res || fetch(e.request)));
                });
            `;
            const blob = new Blob([swCode], {type: 'application/javascript'});
            if('serviceWorker' in navigator) {
                navigator.serviceWorker.register(URL.createObjectURL(blob)).catch(console.error);
            }
        };

        // Keyboard Shortcuts
        window.addEventListener('keydown', e => {
            if(e.ctrlKey && e.shiftKey && e.key.toLowerCase() === 'r') {
                e.preventDefault();
                !appState.isRecording ? document.getElementById('btn-start-record').click() : document.getElementById('btn-stop-record').click();
            }
        });

    </script>
</body>
