                    <h2>Welcome to Nexra Workspace</h2>
                    <p style="color: var(--text-muted); margin-top: 10px;">Select your recording parameters and jump into the studio.</p>
                    <div class="flex gap-4" style="margin-top: 30px;">
                        <button class="btn btn-primary" onclick="app.navigate('studio')">New Recording</button>
                    </div>
                </div>
                <div id="dash-history" class="hidden">
                    <h2>Local Recording History</h2>
                    <p style="color: var(--text-muted); margin-top: 10px;">Past recordings are stored temporarily in your browser's memory.</p>
                    <ul id="history-list" style="margin-top: 20px; list-style: none;">
